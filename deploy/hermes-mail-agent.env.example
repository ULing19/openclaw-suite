MAIL_AGENT_IMAP_SERVER=mail.example.com
MAIL_AGENT_IMAP_PORT=993
MAIL_AGENT_SMTP_SERVER=mail.example.com
MAIL_AGENT_SMTP_PORT=587
MAIL_AGENT_SMTP_SECURITY=starttls
MAIL_AGENT_EMAIL_ACCOUNT=bot@example.com
MAIL_AGENT_EMAIL_PASSWORD=CHANGE_ME

MAIL_AGENT_MINIMAX_API_KEY=CHANGE_ME
MAIL_AGENT_MINIMAX_URL=https://api.minimaxi.com/anthropic/v1/messages
MAIL_AGENT_MINIMAX_HOST=https://api.minimaxi.com
MAIL_AGENT_MODEL=MiniMax-M2.7
MAIL_AGENT_BRAVE_KEY=CHANGE_ME

MAIL_AGENT_STATE_FILE=/opt/openclaw-multimodal-toolkit/state.json
MAIL_AGENT_SIGNATURE=This email was generated automatically by an AI assistant

# Optional OpenClaw notification targets JSON.
# Example:
# MAIL_AGENT_NOTIFY_TARGETS=[{"channel":"telegram","target":"telegram:<user_id>"}]
MAIL_AGENT_NOTIFY_TARGETS=[]
