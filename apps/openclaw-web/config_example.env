# OpenClaw Web Configuration Template
# Copy this to .env and fill in your values

# MiniMax API Key
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional model/image backends
VIVIAI_API_KEY=
AIPAIBOX_API_KEY=

# Web token signing secret
OPENCLAW_WEB_TOKEN_SECRET=change_me_to_a_random_secret

# Paths (optional)
OPENCLAW_WEB_DATA_DIR=./data
OPENCLAW_WEB_ARTIFACTS_DIR=./artifacts/tasks
OPENCLAW_WEB_STATIC_DIR=./static
